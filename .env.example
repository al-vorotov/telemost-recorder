# --- Core ---
# Локально (sqlite):
DATABASE_URL=sqlite+aiosqlite:///./data/telemost.db
# Docker compose подставляет postgres URL автоматически для gateway
# DATABASE_URL=postgresql+asyncpg://recorder:recorder@localhost:5432/telemost_recorder
SIMULATE_MEETING=false
SIMULATE_TRANSCRIPTION=false
# SIMULATE_MEETING=true + SIMULATE_TRANSCRIPTION=true — полный dev без браузера и Whisper
GATEWAY_BASE_URL=http://127.0.0.1:8000
SCHEDULE_TIMEZONE=Europe/Moscow
RETENTION_SWEEP_INTERVAL_HOURS=1

# LLM summary (опционально, OpenAI-compatible API)
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
REDIS_URL=redis://localhost:6379/0
DATA_DIR=./data

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
ALLOWED_TELEGRAM_IDS=123456789
BOT_API_SECRET=change-me

# --- Gateway ---
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000
BOT_DISPLAY_NAME=Recorder Bot
MAX_CONCURRENT_SESSIONS=1
AUDIO_RETENTION_DAYS=7

# --- Whisper (transcriber) ---
WHISPER_MODEL=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_LANGUAGE=ru

# --- Meeting worker ---
MEETING_WORKER_HEADLESS=false
DISPLAY=:99
